taxonomy.json
*.tmp

# 산출물(스프레드시트/CSV)
*.xlsx
*.xlsm
*.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# OS / 편집기
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
